{
  "name": "onair",
  "version": "1.1.0",
  "description": "onAIr — AI-powered presentation teleprompter overlay for Windows",
  "main": "main.js",
  "author": "Rafael Souza",
  "license": "MIT",
  "keywords": [
    "teleprompter",
    "overlay",
    "electron",
    "presentation",
    "AI",
    "whisper"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rafasouza_microsoft/onair.git"
  },
  "scripts": {
    "start": "cmd /C \"set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "build": "cmd /C \"set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win\"",
    "build:portable": "cmd /C \"set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable\""
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.onair.app",
    "productName": "onAIr",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/app-icon.ico"
    },
    "fileAssociations": [
      {
        "ext": "txt",
        "name": "Text File",
        "description": "Open with onAIr",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "rafasouza_microsoft",
      "repo": "onair",
      "private": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
